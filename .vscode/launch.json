{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
            "sourceMaps": true,
            "outFiles": ["${workspaceFolder}/out/src/**/*.js"],
            "preLaunchTask": "npm: compile"
        }
    ]
}
